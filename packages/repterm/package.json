{
    "name": "repterm",
    "version": "0.1.0",
    "description": "CLI/TUI test framework with Playwright-style API",
    "type": "module",
    "bin": {
        "repterm": "./dist/cli/index.js"
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsc",
        "build:bin": "bun build ./src/cli/index.ts --compile --outfile dist/repterm",
        "clean": "rm -rf dist"
    },
    "keywords": [
        "testing",
        "tui",
        "terminal",
        "cli",
        "playwright"
    ],
    "author": "",
    "license": "MIT",
    "dependencies": {
        "bun-pty": "^0.4.4"
    },
    "devDependencies": {
        "@types/bun": "latest",
        "typescript": "^5.3.0"
    }
}