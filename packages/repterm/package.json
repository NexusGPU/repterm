{
  "name": "repterm",
  "version": "0.1.1",
  "description": "CLI/TUI test framework with Playwright-style API",
  "type": "module",
  "bin": {
    "repterm": "./dist/cli/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "build:bin": "bun build ./src/cli/index.ts --compile --outfile dist/repterm",
    "build:bin:all": "bun run scripts/compile-all.ts",
    "clean": "rm -rf dist release"
  },
  "keywords": [
    "testing",
    "tui",
    "terminal",
    "cli",
    "playwright"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bun-pty": "^0.4.4",
    "repterm-api": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.3.0"
  }
}
