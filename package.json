{
  "name": "repterm",
  "version": "0.1.0",
  "description": "CLI/TUI test framework with Playwright-style API",
  "type": "module",
  "bin": {
    "repterm": "./src/cli/index.ts"
  },
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "scripts": {
    "dev": "bun --watch src/cli/index.ts",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\""
  },
  "keywords": [
    "testing",
    "tui",
    "terminal",
    "cli",
    "playwright"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bun-pty": "^0.4.4"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "eslint": "^9.39.2",
    "prettier": "^3.0.0",
    "typescript": "^5.3.0"
  }
}